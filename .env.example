# ═══════════════════════════════════════════════════════════════════════════════
# PersEng CLI 配置
# ═══════════════════════════════════════════════════════════════════════════════
# 启动场景：perseng run / serve-http / feishu / serve / feishu-multi
# 查看所有配置：perseng doctor
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# 一、必填配置
# ─────────────────────────────────────────────────────────────────────────────

# 【LLM】选择一家填写；Anthropic 和 OpenAI 兼容二选一
# ── Anthropic（推荐 Claude 模型）
# ANTHROPIC_API_KEY=sk-ant-your-key

# ── OpenAI 兼容（Moonshot / DeepSeek / OpenRouter / Kimi 等）
# OPENAI_API_KEY=sk-your-key
# PERSENG_API_BASE=https://api.moonshot.cn/v1   # OpenAI 兼容端点

# 【角色】默认加载的角色
# PERSENG_ROLE=jiangziya

# 【模型】默认使用的模型（覆盖角色的默认模型）
# PERSENG_MODEL=moonshot-v1-8k

# ─────────────────────────────────────────────────────────────────────────────
# 二、可选服务集成
# ─────────────────────────────────────────────────────────────────────────────

# 【飞书机器人】https://open.feishu.cn/app 创建企业自建应用
# FEISHU_APP_ID=cli_xxx
# FEISHU_APP_SECRET=xxx
# FEISHU_BOT_OPEN_ID=   # 精确 @ 判定（可选）
# PERSENG_FEISHU_ALLOW_USERS=   # 用户白名单（空=全部）
# PERSENG_FEISHU_ALLOW_GROUPS=  # 群白名单（空=全部）
# PERSENG_FEISHU_ROLE_ADMINS=   # 角色切换管理员（可切换 /role）

# 【GBrain 知识库】本地 RAG 服务
# GBRAIN_URL=http://localhost:7333
# GBRAIN_HTTP_TOKEN=your-token
# GBRAIN_BRAIN_AREA=perseng
# GBRAIN_TIMEOUT_MS=15000

# 【Multica IDE】IDE 集成
# MULTICA_TOKEN=
# MULTICA_SERVER_URL=
# MULTICA_WORKSPACE_ID=

# ─────────────────────────────────────────────────────────────────────────────
# 三、WebUI / HTTP API（serve-http 模式）
# ─────────────────────────────────────────────────────────────────────────────

# PERSENG_HTTP_HOST=127.0.0.1
# PERSENG_HTTP_PORT=7717
# PERSENG_HTTP_TOKEN=              # API Token（设置后需 Bearer 认证）
# PERSENG_HTTP_MAX_SESSIONS=20     # 最大 WebSocket 会话数

# ─────────────────────────────────────────────────────────────────────────────
# 四、网络与安全策略
# ─────────────────────────────────────────────────────────────────────────────

# 【网络】允许访问外部网络（web-search / web-fetch / url-to-markdown）
# PERSENG_ALLOW_NETWORK=1

# 【命令执行】黑名单/白名单控制
# PERSENG_BLOCK_RUN_COMMAND=0     # 完全禁用 run_command
# PERSENG_RUN_COMMAND_ALLOWLIST=  # 白名单模式（逗号分隔：git,ls,node）
# PERSENG_ALLOW_PATH_OUTSIDE_CWD=0  # 允许访问 cwd 外的路径
# PERSENG_FOLLOW_SYMLINKS=0       # 允许跟随符号链接

# ─────────────────────────────────────────────────────────────────────────────
# 五、Web Search 搜索配置
# ─────────────────────────────────────────────────────────────────────────────

# 后端选择（按优先级：API Key > DuckDuckGo）
# DuckDuckGo（默认，免费，无需 API Key）
# Brave Search（付费，更精准）→ 配置 BRAVE_API_KEY
# Tavily（付费，更精准）→ 配置 TAVILY_API_KEY
# SerpAPI（付费，Google 结果）→ 配置 SERPAPI_API_KEY
# BRAVE_API_KEY=
# TAVILY_API_KEY=
# SERPAPI_API_KEY=

# 搜索参数
# PERSENG_WEB_SEARCH_MAX_RESULTS=10   # 返回条数（1-50，默认 10）
# PERSENG_WEB_SEARCH_TIMEOUT_MS=15000 # 超时（毫秒）
# PERSENG_WEB_SEARCH_BACKEND=         # 强制后端（duckduckgo/brave/tavily/serpapi）

# ─────────────────────────────────────────────────────────────────────────────
# 六、模型细分（可选，覆盖默认模型）
# ─────────────────────────────────────────────────────────────────────────────

# PERSENG_MODEL_IDLE=        # 空闲时使用的模型
# PERSENG_MODEL_GOAL=        # 目标分解模型
# PERSENG_MODEL_PLANNING=    # 规划模型
# PERSENG_MODEL_EXECUTION=   # 执行模型
# PERSENG_MODEL_REFLECTION=  # 反思模型

# ─────────────────────────────────────────────────────────────────────────────
# 七、输出与日志
# ─────────────────────────────────────────────────────────────────────────────

# 【Thinking】是否显示思考过程（<thinking> 标签内容）
# PERSENG_SHOW_THINKING=1   # 1=显示，0=隐藏（推荐生产环境隐藏）

# 【日志】
# PERSENG_DEBUG=0
# PERSENG_LOG_LEVEL=info    # debug / info / warn / error
# PERSENG_LOG_PRETTY=0      # 人类可读格式

# ─────────────────────────────────────────────────────────────────────────────
# 八、存储路径（通常不需要修改）
# ─────────────────────────────────────────────────────────────────────────────

# 默认统一落到 ~/.perseng-cli（Linux/Mac）或 %APPDATA%/perseng-cli（Windows）
# PERSENG_CLI_DATA_DIR=        # 主目录
# PERSENG_CLI_COGNITION_DIR=   # 记忆目录
# PERSENG_CLI_ROLEX_DIR=       # 角色目录
# PERSENG_CLI_BLACKBOARD_DIR=  # Agent 通信目录
# PERSENG_CLI_TIMELINE_DIR=    # 时间线目录

# ─────────────────────────────────────────────────────────────────────────────
# 九、重试与限制
# ─────────────────────────────────────────────────────────────────────────────

# PERSENG_LLM_RETRY=1              # 启用重试
# PERSENG_LLM_MAX_RETRIES=3        # 最大重试次数
# PERSENG_LLM_BASE_DELAY_MS=500    # 重试基础延迟
# PERSENG_MAX_MEMORIES_PER_ROLE=500 # 每角色最大记忆数
# PERSENG_ROLES_CACHE_LIMIT=32     # 角色缓存上限

# ═══════════════════════════════════════════════════════════════════════════════
