# ===== Core =====
PERSENG_ROLE=jiangziya
PERSENG_MODEL=claude-sonnet-4-20250514
# PERSENG_MODEL_IDLE=
# PERSENG_MODEL_GOAL=
# PERSENG_MODEL_PLANNING=
# PERSENG_MODEL_EXECUTION=
# PERSENG_MODEL_REFLECTION=

# ===== LLM =====
# 任选其一；如果同时配置，运行时会优先按当前 provider 逻辑选用
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# 使用 OpenAI 兼容端点时填写，例如 Moonshot / DeepSeek / OpenRouter
PERSENG_API_BASE=

# ===== Multica =====
MULTICA_TOKEN=
MULTICA_SERVER_URL=
MULTICA_WORKSPACE_ID=

# ===== Feishu =====
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# FEISHU_BOT_OPEN_ID=
# PERSENG_FEISHU_ALLOW_USERS=u_xxx,u_yyy
# PERSENG_FEISHU_ALLOW_GROUPS=oc_xxx,oc_yyy
# PERSENG_FEISHU_ROLE_ADMINS=u_xxx
# PERSENG_ASR_MODEL=whisper-1

# ===== GBrain =====
# GBRAIN_URL=https://your-gbrain.example.com
# GBRAIN_HTTP_TOKEN=
# GBRAIN_BRAIN_AREA=perseng
# GBRAIN_TIMEOUT_MS=15000

# ===== HTTP WebUI / API =====
PERSENG_HTTP_HOST=127.0.0.1
PERSENG_HTTP_PORT=7717
# PERSENG_HTTP_TOKEN=
PERSENG_HTTP_MAX_SESSIONS=20

# ===== Storage =====
# 默认统一落到 ~/.perseng-cli；按需覆盖
# PERSENG_CLI_DATA_DIR=
# PERSENG_CLI_COGNITION_DIR=
# PERSENG_CLI_ROLEX_DIR=
# PERSENG_CLI_BLACKBOARD_DIR=
# PERSENG_CLI_TIMELINE_DIR=

# ===== Policy =====
# PERSENG_ALLOW_NETWORK=0
# PERSENG_ALLOW_PATH_OUTSIDE_CWD=0
# PERSENG_BLOCK_RUN_COMMAND=0
# PERSENG_RUN_COMMAND_ALLOWLIST=git,multica
# PERSENG_FOLLOW_SYMLINKS=0

# ===== Observability =====
# PERSENG_DEBUG=0
# PERSENG_LOG_LEVEL=info
# PERSENG_LOG_PRETTY=0

# ===== Retry / Limits =====
# PERSENG_LLM_RETRY=1
# PERSENG_LLM_MAX_RETRIES=3
# PERSENG_LLM_BASE_DELAY_MS=500
# PERSENG_MAX_MEMORIES_PER_ROLE=500
# PERSENG_ROLES_CACHE_LIMIT=32
